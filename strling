#!/bin/bash
set -o pipefail

DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"
TOOLCHAIN="$DIR/toolchain.json"
SELF="$DIR/strling"

if ! command -v python3 >/dev/null 2>&1; then
    echo "Error: python3 is required to run this script."
    exit 1
fi

get_python_venv_dir() {
    local py_version
    py_version=$(python3 -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')" 2>/dev/null || echo "3")
    echo ".venv-${py_version}"
}

print_banner() {
    cat <<'EOF'
   _____ _______ _____  _ _
  / ____|__   __|  __ \| (_)
 | (___    | |  | |__) | |_ _ __   __ _
  \___ \   | |  |  _  /| | | '_ \ / _` |
  ____) |  | |  | | \ \| | | | | | (_| |
 |_____/   |_|  |_|  \_\_|_|_| |_|\__, |
                                   __/ |
                                  |___/

EOF
}

get_binding_names() {
    python3 - "$TOOLCHAIN" <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as handle:
    bindings = json.load(handle)["bindings"]
for name in sorted(bindings):
    print(name)
PY
}

get_binding_scalar() {
    local lang="$1"
    local field="$2"
    python3 - "$TOOLCHAIN" "$lang" "$field" <<'PY'
import json
import sys

toolchain_path, lang, field = sys.argv[1:]
with open(toolchain_path, "r", encoding="utf-8") as handle:
    binding = json.load(handle)["bindings"].get(lang, {})
value = binding.get(field, "")
if isinstance(value, (list, dict)):
    print("")
else:
    print(value)
PY
}

binding_has_action() {
    local lang="$1"
    local action="$2"
    python3 - "$TOOLCHAIN" "$lang" "$action" <<'PY'
import json
import sys

toolchain_path, lang, action = sys.argv[1:]
with open(toolchain_path, "r", encoding="utf-8") as handle:
    binding = json.load(handle)["bindings"].get(lang, {})
value = binding.get(action, [])
print("1" if value else "0")
PY
}

get_binding_required_bins() {
    local lang="$1"
    python3 - "$TOOLCHAIN" "$lang" <<'PY'
import json
import sys

toolchain_path, lang = sys.argv[1:]
with open(toolchain_path, "r", encoding="utf-8") as handle:
    binding = json.load(handle)["bindings"].get(lang, {})
required = binding.get("required_bins") or []
if not required:
    check_bin = binding.get("check_bin")
    required = [check_bin] if check_bin else []
for item in required:
    if item:
        print(item)
PY
}

get_binding_install_packages() {
    local lang="$1"
    local manager="$2"
    python3 - "$TOOLCHAIN" "$lang" "$manager" <<'PY'
import json
import sys

toolchain_path, lang, manager = sys.argv[1:]
with open(toolchain_path, "r", encoding="utf-8") as handle:
    binding = json.load(handle)["bindings"].get(lang, {})
packages = binding.get("install", {}).get(manager, [])
for item in packages:
    print(item)
PY
}

get_binding_command_args() {
    local lang="$1"
    local action="$2"
    python3 - "$TOOLCHAIN" "$lang" "$action" <<'PY'
import json
import sys

toolchain_path, lang, action = sys.argv[1:]
with open(toolchain_path, "r", encoding="utf-8") as handle:
    binding = json.load(handle)["bindings"].get(lang, {})
value = binding.get(action, [])
if isinstance(value, str):
    value = [value]
for item in value:
    sys.stdout.write(item)
    sys.stdout.write("\0")
PY
}

get_binding_command_string() {
    local lang="$1"
    local action="$2"
    python3 - "$TOOLCHAIN" "$lang" "$action" <<'PY'
import json
import shlex
import sys

toolchain_path, lang, action = sys.argv[1:]
with open(toolchain_path, "r", encoding="utf-8") as handle:
    binding = json.load(handle)["bindings"].get(lang, {})
value = binding.get(action, [])
if isinstance(value, str):
    value = [value]
print(shlex.join(value))
PY
}

detect_package_manager() {
    if command -v apt-get >/dev/null 2>&1; then
        echo "apt"
    elif command -v dnf >/dev/null 2>&1; then
        echo "dnf"
    elif command -v pacman >/dev/null 2>&1; then
        echo "pacman"
    elif command -v brew >/dev/null 2>&1; then
        echo "brew"
    else
        echo ""
    fi
}

install_packages() {
    local manager="$1"
    shift
    local packages=("$@")
    local prefix=()

    if [[ ${#packages[@]} -eq 0 ]]; then
        return 1
    fi

    if [[ "$manager" != "brew" && "$EUID" -ne 0 ]]; then
        if command -v sudo >/dev/null 2>&1 && sudo -n true >/dev/null 2>&1; then
            prefix=(sudo -n)
        else
            echo ">> Cannot auto-install packages without non-interactive sudo access."
            return 1
        fi
    fi

    echo ">> Attempting prerequisite install via $manager: ${packages[*]}"
    case "$manager" in
        apt)
            "${prefix[@]}" apt-get update && DEBIAN_FRONTEND=noninteractive "${prefix[@]}" apt-get install -y "${packages[@]}"
            ;;
        dnf)
            "${prefix[@]}" dnf install -y "${packages[@]}"
            ;;
        pacman)
            "${prefix[@]}" pacman -Sy --noconfirm "${packages[@]}"
            ;;
        brew)
            brew install "${packages[@]}"
            ;;
        *)
            return 1
            ;;
    esac
}

attempt_binding_install() {
    local lang="$1"
    local manager
    local packages=()

    manager=$(detect_package_manager)
    if [[ -z "$manager" ]]; then
        echo ">> No supported package manager detected for automatic prerequisite installation."
        return 1
    fi

    readarray -t packages < <(get_binding_install_packages "$lang" "$manager")
    if [[ ${#packages[@]} -eq 0 ]]; then
        echo ">> No install metadata is defined for '$lang' on package manager '$manager'."
        return 1
    fi

    install_packages "$manager" "${packages[@]}"
}

ensure_binding_prereqs() {
    local lang="$1"
    local required_bins=()
    local missing=()

    readarray -t required_bins < <(get_binding_required_bins "$lang")
    if [[ ${#required_bins[@]} -eq 0 ]]; then
        return 0
    fi

    for required_bin in "${required_bins[@]}"; do
        if ! command -v "$required_bin" >/dev/null 2>&1; then
            missing+=("$required_bin")
        fi
    done

    if [[ ${#missing[@]} -eq 0 ]]; then
        return 0
    fi

    echo ">> Missing prerequisite tools for $lang: ${missing[*]}"
    if ! attempt_binding_install "$lang"; then
        return 1
    fi

    missing=()
    for required_bin in "${required_bins[@]}"; do
        if ! command -v "$required_bin" >/dev/null 2>&1; then
            missing+=("$required_bin")
        fi
    done

    if [[ ${#missing[@]} -gt 0 ]]; then
        echo ">> Prerequisites are still missing for $lang after install attempt: ${missing[*]}"
        return 1
    fi

    return 0
}

list_bindings() {
    echo "Available Bindings:"
    while IFS= read -r binding; do
        local required_bins=()
        local missing=()

        readarray -t required_bins < <(get_binding_required_bins "$binding")
        for required_bin in "${required_bins[@]}"; do
            if ! command -v "$required_bin" >/dev/null 2>&1; then
                missing+=("$required_bin")
            fi
        done

        if [[ ${#missing[@]} -eq 0 ]]; then
            printf "  %-12s [READY]\n" "$binding"
        else
            printf "  %-12s [MISSING: %s]\n" "$binding" "${missing[*]}"
        fi
    done < <(get_binding_names)
}

run_binding_action() {
    local action="$1"
    local lang="$2"
    local binding_path
    local exit_code
    local cmd_string
    local cmd_args=()

    if [[ "$action" == "bootstrap" ]]; then
        "$SELF" setup "$lang" || return 1
        "$SELF" build "$lang" || return 1
        "$SELF" test "$lang" || return 1
        return 0
    fi

    binding_path=$(get_binding_scalar "$lang" "path")
    if [[ -z "$binding_path" ]]; then
        echo "Error: Language '$lang' not found."
        echo "Did you mean one of these?"
        while IFS= read -r binding_name; do
            echo "  - $binding_name"
        done < <(get_binding_names)
        return 1
    fi

    if [[ "$action" != "clean" ]]; then
        ensure_binding_prereqs "$lang" || return 1
    fi

    if [[ "$(binding_has_action "$lang" "$action")" != "1" ]]; then
        echo "No '$action' command defined for $lang."
        return 0
    fi

    mapfile -d '' cmd_args < <(get_binding_command_args "$lang" "$action")
    cmd_string=$(get_binding_command_string "$lang" "$action")

    echo ">> Running $action for $lang in $binding_path..."
    echo ">> Executing: $cmd_string"

    (
        cd "$DIR/$binding_path" || exit 1

        if [[ "$lang" == "python" && "$action" != "clean" ]]; then
            local venv_dir
            venv_dir=$(get_python_venv_dir)
            if [[ -d ".venv" && ! -L ".venv" ]]; then
                echo ">> Removing old non-versioned .venv (migrating to versioned cache)..."
                rm -rf ".venv"
            fi
            if [[ ! -d "$venv_dir" ]]; then
                echo ">> Creating Python virtual environment ($venv_dir)..."
                python3 -m venv "$venv_dir"
            fi
            export PATH="$(pwd)/$venv_dir/bin:$PATH"
            echo ">> Using python env: $(which python) (pip: $(which pip))"
        fi

        if [[ "${cmd_args[0]}" == "dotnet" ]]; then
            bash -lc "$cmd_string"
        else
            "${cmd_args[@]}"
        fi
    )
    exit_code=$?

    if [[ $exit_code -ne 0 ]]; then
        echo ""
        echo "❌ Command failed with exit code $exit_code"
        echo "   Task: $action"
        echo "   Language: $lang"
        if [[ "$action" == "test" || "$action" == "build" ]]; then
            echo "   Hint: Try running './strling setup $lang' first."
        fi
    fi

    return $exit_code
}

run_all_bindings() {
    local action="$1"
    local passed=0
    local failed=0
    local failures=()
    local bindings=()

    readarray -t bindings < <(get_binding_names)
    for binding in "${bindings[@]}"; do
        echo "--------------------------------------------------"
        echo ">> ${action^} $binding"
        if "$SELF" "$action" "$binding"; then
            passed=$((passed + 1))
        else
            failed=$((failed + 1))
            failures+=("$binding")
        fi
    done

    echo "--------------------------------------------------"
    echo ">> Summary: $passed succeeded, $failed failed"
    if [[ ${#failures[@]} -gt 0 ]]; then
        echo ">> Failed bindings: ${failures[*]}"
        return 1
    fi
    return 0
}

print_help() {
    print_banner
    echo "Usage: ./strling <command> <language>"
    echo ""
    echo "Commands:"
    echo "  setup <lang|all>      Install prerequisites and dependencies"
    echo "  build <lang|all>      Build a binding if it has a build step"
    echo "  test <lang|all>       Run tests for one binding or all bindings"
    echo "  bootstrap <lang|all>  Run setup, build, and test in sequence"
    echo "  clean <lang|all>      Clean artifacts"
    echo "  audit                 Run the final audit report generator"
    echo "  cache-dir <lang>      Print cache directory path (for CI)"
    echo "  lockfile <lang>       Print lockfile name (for CI)"
    echo "  list                  List all bindings and tool status"
    echo "  help                  Show this help message"
    echo ""
    echo "Examples:"
    echo "  ./strling bootstrap all"
    echo "  ./strling test python"
    echo "  ./strling setup rust"
    echo "  ./strling audit"
    echo ""
    list_bindings
}

COMMAND="$1"
LANG="$2"

if [[ ! -f "$TOOLCHAIN" ]]; then
    echo "Error: toolchain.json not found at $TOOLCHAIN"
    exit 1
fi

if [[ -z "$COMMAND" || "$COMMAND" == "help" || "$COMMAND" == "-h" || "$COMMAND" == "--help" ]]; then
    print_help
    exit 0
fi

if [[ "$COMMAND" == "list" ]]; then
    print_banner
    list_bindings
    exit 0
fi

if [[ "$COMMAND" == "audit" ]]; then
    cd "$DIR" || exit 1
    python3 tooling/audit_omega.py
    exit $?
fi

if [[ "$COMMAND" == "cache-dir" ]]; then
    if [[ -z "$LANG" ]]; then
        echo ""
        exit 1
    fi
    case "$LANG" in
        php)
            echo "${HOME}/.cache/composer"
            echo "bindings/php/vendor"
            ;;
        typescript|javascript|node)
            echo "${HOME}/.npm"
            echo "bindings/typescript/node_modules"
            ;;
        rust)
            echo "${HOME}/.cargo/registry"
            echo "${HOME}/.cargo/git"
            echo "bindings/rust/target"
            ;;
        python)
            PY_VERSION=$(python3 -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')" 2>/dev/null || echo "3")
            echo "${HOME}/.cache/pip"
            echo "bindings/python/.venv-${PY_VERSION}"
            ;;
        go)
            echo "${HOME}/go/pkg/mod"
            echo "${HOME}/.cache/go-build"
            ;;
        ruby)
            echo "bindings/ruby/vendor/bundle"
            ;;
        dart)
            echo "${HOME}/.pub-cache"
            echo "bindings/dart/.dart_tool"
            ;;
        java|kotlin)
            echo "${HOME}/.m2/repository"
            echo "${HOME}/.gradle/caches"
            echo "bindings/java/target"
            echo "bindings/kotlin/build"
            ;;
        lua)
            echo "bindings/lua/.luarocks"
            ;;
        perl)
            echo "bindings/perl/local"
            ;;
        csharp)
            echo "${HOME}/.nuget/packages"
            echo "bindings/csharp/src/STRling/obj"
            echo "bindings/csharp/src/STRling/bin"
            echo "bindings/csharp/tests/STRling.Tests/obj"
            echo "bindings/csharp/tests/STRling.Tests/bin"
            ;;
        fsharp)
            echo "${HOME}/.nuget/packages"
            echo "bindings/fsharp/src/STRling/obj"
            echo "bindings/fsharp/src/STRling/bin"
            echo "bindings/fsharp/tests/STRling.Tests/obj"
            echo "bindings/fsharp/tests/STRling.Tests/bin"
            ;;
        swift)
            echo "${HOME}/.swiftpm"
            echo "bindings/swift/.build"
            ;;
        c)
            echo "bindings/c/build"
            ;;
        cpp)
            echo "bindings/cpp/build"
            ;;
        r)
            echo "bindings/r/renv/library"
            ;;
        *)
            echo ""
            ;;
    esac
    exit 0
fi

if [[ "$COMMAND" == "lockfile" ]]; then
    if [[ -z "$LANG" ]]; then
        echo ""
        exit 1
    fi
    case "$LANG" in
        php)
            echo "composer.lock"
            ;;
        typescript|javascript|node)
            echo "package-lock.json"
            ;;
        rust)
            echo "Cargo.lock"
            ;;
        python)
            echo "requirements.txt"
            ;;
        go)
            if [[ -f "bindings/go/go.sum" ]]; then
                echo "go.sum"
            else
                echo "go.mod"
            fi
            ;;
        ruby)
            echo "Gemfile.lock"
            ;;
        dart)
            echo "pubspec.lock"
            ;;
        java)
            echo "pom.xml"
            ;;
        kotlin)
            echo "build.gradle.kts"
            ;;
        lua)
            echo "strling-3.0.0-1.rockspec"
            ;;
        perl)
            echo "Makefile.PL"
            ;;
        csharp)
            echo "src/STRling/STRling.csproj"
            ;;
        fsharp)
            echo "src/STRling/STRling.fsproj"
            ;;
        swift)
            if [[ -f "bindings/swift/Package.resolved" ]]; then
                echo "Package.resolved"
            else
                echo "Package.swift"
            fi
            ;;
        c)
            echo "Makefile"
            ;;
        cpp)
            echo "CMakeLists.txt"
            ;;
        r)
            echo "DESCRIPTION"
            ;;
        *)
            echo ""
            ;;
    esac
    exit 0
fi

if [[ -z "$LANG" ]]; then
    echo "Error: Language argument is required for '$COMMAND'."
    echo "Usage: ./strling $COMMAND <language>"
    exit 1
fi

if [[ "$LANG" == "all" && ( "$COMMAND" == "setup" || "$COMMAND" == "build" || "$COMMAND" == "test" || "$COMMAND" == "bootstrap" || "$COMMAND" == "clean" ) ]]; then
    run_all_bindings "$COMMAND"
    exit $?
fi

if [[ "$COMMAND" == "clean" ]]; then
    binding_path=$(get_binding_scalar "$LANG" "path")
    if [[ -z "$binding_path" ]]; then
        echo "Error: Language '$LANG' not found in toolchain.json"
        exit 1
    fi

    echo ">> Cleaning artifacts in $DIR/$binding_path..."
    find "$DIR/$binding_path" -type d \( -name "build" -o -name "target" -o -name "dist" -o -name "vendor" -o -name "__pycache__" -o -name ".venv" -o -name ".venv-*" \) -prune -exec rm -rf {} +
    echo ">> Clean complete for $LANG."
    exit 0
fi

run_binding_action "$COMMAND" "$LANG"
exit $?

